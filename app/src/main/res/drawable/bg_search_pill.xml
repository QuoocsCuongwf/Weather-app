<?xml version="1.0" encoding="utf-8"?>
<!--
    Pill-shaped background for the search bar.
    Semi-transparent white (glassmorphism effect) with full rounded corners.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- ~20% white tint — sits nicely over the blue gradient -->
    <solid android:color="#33FFFFFF" />

    <corners android:radius="28dp" />

    <!-- Very subtle stroke to give the pill definition -->
    <stroke
        android:width="1dp"
        android:color="#44FFFFFF" />
</shape>
